---
import Layout from "../layouts/Layout.astro";
import BlogPostCard from "../components/BlogPostCard.astro";
import GalleryGrid from "../components/GalleryGrid.astro";
import ProfileCard from "../components/ProfileCard.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

// Fetch latest 3 published posts
const allPosts = (
  await getCollection("blog", (entry) => !entry.data.draft)
).sort(
  (a, b) =>
    new Date(b.data.updatedAt ?? b.data.createdAt).getTime() -
    new Date(a.data.updatedAt ?? a.data.createdAt).getTime(),
);
const latestPosts = allPosts.slice(0, 3);

const texts = [
  "Hello World,",
  "I am Giray Coskun.",
  "Follow the white rabbit!",
];

const contactLinks = [
  { label: "Email", href: "mailto:giraycoskun1999@gmail.com", icon: "email" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/giraycoskun", icon: "linkedin" },
  { label: "GitHub", href: "https://github.com/giraycoskun", icon: "github" },
  { label: "Spotify", href: "https://open.spotify.com/user/11151152114", icon: "spotify" },
  { label: "Instagram", href: "https://instagram.com/giray_coskun", icon: "instagram" },
  { label: "Scholar", href: "https://scholar.google.com/citations?user=sbQ5XwUAAAAJ&hl=en&authuser=3", icon: "scholar" },
];
---

<Layout title="Home">
  {/* Hero Section */}
  <div class="bg-gray-200 dark:bg-gray-900">
    <div class="container mx-auto px-6 py-24">
      <div class="flex flex-wrap items-center justify-between gap-8">
        <div class="flex-1 min-w-75 text-center md:text-left">
          <h1
            id="hero"
            data-texts={JSON.stringify(texts)}
            class="text-5xl md:text-6xl font-extrabold text-gray-900 dark:text-gray-100 mb-6"
            aria-live="polite"
          >
            <span id="hero-text">Hello World,</span>
            <span class="hero-cursor" aria-hidden="true">|</span>
          </h1>
          <p class="mt-6 text-lg md:text-xl text-gray-600 dark:text-gray-300">
            I am a Computer Scientist/Software Engineer, living in Munich. <br
            />
            I am also a CMAS 3* Scuba Diver and a hiking enthusiast. <br />
            This is my personal website to write about my projects, hobbies and trips.
          </p>
          <div class="mt-12 flex flex-wrap gap-3 justify-center md:justify-start">
            <button
              id="open-contact-modal"
              type="button"
              class="inline-flex items-center gap-2 bg-emerald-500 dark:bg-emerald-400 hover:bg-emerald-400 dark:hover:bg-emerald-300 text-white dark:text-gray-900 px-4 py-2 rounded border-2 border-black dark:border-emerald-200 transition-colors"
              aria-haspopup="dialog"
              aria-controls="contact-modal"
            >
              Contact
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
                ></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
            </button>
            <a
              href="https://server.giraycoskun.dev"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-gray-300 dark:bg-gray-600 hover:bg-gray-400 dark:hover:bg-gray-500 text-gray-700 dark:text-gray-200 px-4 py-2 rounded border-2 border-black dark:border-gray-400 transition-colors"
              title="Visit server.giraycoskun.dev"
              aria-label="Visit server.giraycoskun.dev"
            >
              Visit my localhost
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
                ></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
            </a>
          </div>
        </div>
        <div class="shrink-0 mx-auto">
          <Image
            src="/banner.jpeg"
            alt="Profile"
            class="w-75 md:w-100 h-auto rounded-lg shadow-lg"
            width={400}
            height={400}
            loading="eager"
          />
        </div>
      </div>
    </div>
  </div>

  <div
    id="contact-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-6"
    role="dialog"
    aria-modal="true"
    aria-labelledby="contact-modal-title"
  >
    <div
      class="w-full max-w-2xl rounded-2xl border-2 border-black dark:border-gray-400 bg-white dark:bg-gray-800 p-6 md:p-8 shadow-2xl"
    >
      <div class="flex items-center justify-between gap-4">
        <div>
          <h2
            id="contact-modal-title"
            class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-gray-100"
          >
            Let's connect
          </h2>
          <p class="mt-1 text-sm text-gray-600 dark:text-gray-300">
            Pick your preferred channel.
          </p>
        </div>
        <button
          id="close-contact-modal"
          type="button"
          class="rounded border border-gray-700 dark:border-gray-300 px-3 py-1 text-sm text-gray-800 dark:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-700"
          aria-label="Close contact modal"
        >
          Close
        </button>
      </div>
      <ul class="mt-6 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
        {
          contactLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target={link.href.startsWith("mailto:") ? undefined : "_blank"}
                rel={link.href.startsWith("mailto:") ? undefined : "noopener noreferrer"}
                class="group flex flex-col items-center justify-center gap-1 rounded-xl border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900/40 px-3 py-4 text-gray-800 dark:text-gray-100 hover:bg-white dark:hover:bg-gray-700 hover:-translate-y-0.5 transition-all"
              >
                {
                  link.icon === "github" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="h-6 w-6"
                      aria-hidden="true"
                    >
                      <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.009-.868-.014-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.071 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.349-1.088.635-1.338-2.221-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.03-2.688-.103-.253-.447-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.563 9.563 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.026 2.747-1.026.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.31.678.92.678 1.855 0 1.338-.012 2.418-.012 2.747 0 .268.18.58.688.481A10.02 10.02 0 0 0 22 12.017C22 6.484 17.523 2 12 2z"></path>
                    </svg>
                  )
                }
                {
                  link.icon === "instagram" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      class="h-6 w-6"
                      aria-hidden="true"
                    >
                      <rect x="3" y="3" width="18" height="18" rx="5"></rect>
                      <circle cx="12" cy="12" r="4"></circle>
                      <circle cx="17.5" cy="6.5" r="1"></circle>
                    </svg>
                  )
                }
                {
                  link.icon === "spotify" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="h-6 w-6"
                      aria-hidden="true"
                    >
                      <path d="M12 1.5a10.5 10.5 0 1 0 0 21 10.5 10.5 0 0 0 0-21Zm4.723 15.15a.84.84 0 0 1-1.157.278c-3.17-1.938-7.158-2.377-11.854-1.306a.84.84 0 0 1-.373-1.638c5.137-1.172 9.551-.67 13.101 1.5a.84.84 0 0 1 .283 1.166Zm1.65-3.67a1.05 1.05 0 0 1-1.447.348c-3.629-2.23-9.16-2.875-13.452-1.569a1.05 1.05 0 1 1-.611-2.009c4.89-1.486 11.011-.767 15.16 1.783a1.05 1.05 0 0 1 .35 1.447Zm.142-3.824C14.162 6.57 6.967 6.327 2.81 7.592a1.26 1.26 0 0 1-.734-2.412c4.771-1.451 12.708-1.169 17.756 1.836a1.26 1.26 0 0 1-1.317 2.14Z"></path>
                    </svg>
                  )
                }
                {
                  link.icon === "linkedin" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="h-6 w-6"
                      aria-hidden="true"
                    >
                      <path d="M4.98 3.5a2.5 2.5 0 1 1 0 5.001 2.5 2.5 0 0 1 0-5ZM3 9h3.96v12H3V9Zm7.02 0H13.8v1.64h.05c.52-.98 1.8-2.01 3.7-2.01 3.96 0 4.69 2.61 4.69 6V21h-3.96v-5.65c0-1.35-.02-3.08-1.88-3.08-1.88 0-2.17 1.47-2.17 2.99V21H10.02V9Z"></path>
                    </svg>
                  )
                }
                {
                  link.icon === "scholar" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="h-6 w-6"
                      aria-hidden="true"
                    >
                      <path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z"></path>
                    </svg>
                  )
                }
                {
                  link.icon === "email" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      class="h-6 w-6"
                      aria-hidden="true"
                    >
                      <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                      <path d="m4 7 8 6 8-6"></path>
                    </svg>
                  )
                }
                <span class="text-sm font-medium group-hover:underline">{link.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  {/* Latest posts section */}
  <div class="bg-white dark:bg-gray-800 py-12">
    <div class="container mx-auto px-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
          Latest posts
        </h2>
        <a
          href="/blog"
          class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline"
        >
          View all posts →
        </a>
      </div>

      {
        latestPosts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-3 gap-6">
            {latestPosts.map((post, i) => (
              <div
                class:list={[
                  { "hidden md:block": i === 2, "hidden lg:block": i >= 3 },
                ]}
              >
                <BlogPostCard
                  title={post.data.title}
                  slug={post.slug}
                  createdAt={post.data.createdAt}
                  description={post.data.description}
                  author={{
                    name: post.data.author.name,
                    avatar: post.data.author.avatar,
                  }}
                  tags={post.data.tags}
                  coverImage={post.data.coverImage}
                />
              </div>
            ))}
          </div>
        ) : (
          <div class="text-gray-600 dark:text-gray-400">
            Check out the{" "}
            <a
              href="/blog"
              class="text-emerald-600 dark:text-emerald-400 hover:underline"
            >
              blog page
            </a>{" "}
            for latest articles.
          </div>
        )
      }
    </div>
  </div>

  {/* Photo Gallery */}
  <div class="bg-gray-200 dark:bg-gray-700 py-12">
    <div class="container mx-auto px-6">
      <GalleryGrid limit={6} random={true} showTitle={true} eagerCount={3} />
    </div>
  </div>

  {/* GitHub Profile Card */}
  <div class="bg-gray-100 dark:bg-gray-900 py-12">
    <div class="container mx-auto px-6">
      <ProfileCard />
    </div>
  </div>

  {/* Spotify Playlists */}
  <div class="hidden md:block bg-gray-200 dark:bg-gray-700 py-12">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <iframe
          data-testid="embed-iframe"
          style="border-radius:12px"
          src="https://open.spotify.com/embed/playlist/4uUbXirh07Hst8ggNeWEOT?utm_source=generator"
          width="100%"
          height="352"
          frameBorder="0"
          allowfullscreen=""
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"></iframe>
        <iframe
          class="w-full rounded-xl border-0"
          style="height: 352px"
          src="https://open.spotify.com/embed/playlist/3C29xT0NaEH7z3MGaPzsCE"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
          title="Spotify Playlist tinilar"></iframe>
      </div>
    </div>
  </div>
  {/* Hardcover Bookcase */}
  <div class="bg-gray-100 dark:bg-gray-800 py-12 content-center">
    <div class="text-center mb-5">
      <a
        href="https://hardcover.app/@giraycoskun/books/currently-reading"
        class="text-2xl font-bold text-gray-900 dark:text-gray-100"
        >Currently Reading || Listening</a
      >
    </div>
    <div data-hardcover-widget id="hardcover-widget"></div>
  </div>
  <style>
    .hero-cursor {
      display: inline-block;
      margin-left: 0.25rem;
      animation: blink 1s step-end infinite;
      color: inherit;
    }

    @keyframes blink {
      50% {
        opacity: 0;
      }
    }
  </style>

  <script>
    (function () {
      const hero = document.getElementById("hero");
      if (!hero) return;
      let texts: string[] = [];
      try {
        texts = JSON.parse(hero.dataset.texts || "[]");
      } catch (e) {
        texts = [];
      }
      if (!texts || texts.length === 0) return;

      const elRaw = document.getElementById("hero-text");
      if (!elRaw) return;
      const el = elRaw as HTMLElement;
      let txtIndex = 0;
      let charIndex = 0;
      let deleting = false;

      const TYPING_SPEED = 80;
      const DELETING_SPEED = 40;
      const PAUSE_AFTER_FULL = 1600;

      function tick() {
        const current = texts[txtIndex] || "";
        if (!deleting) {
          el.textContent = current.substring(0, charIndex + 1);
          charIndex++;
          if (charIndex === current.length) {
            deleting = true;
            setTimeout(tick, PAUSE_AFTER_FULL);
            return;
          }
          setTimeout(tick, TYPING_SPEED);
        } else {
          el.textContent = current.substring(0, charIndex - 1);
          charIndex--;
          if (charIndex === 0) {
            deleting = false;
            txtIndex = (txtIndex + 1) % texts.length;
            setTimeout(tick, 500);
            return;
          }
          setTimeout(tick, DELETING_SPEED);
        }
      }

      // Kick off
      tick();
    })();

    (function () {
      const openBtnRaw = document.getElementById("open-contact-modal");
      const closeBtnRaw = document.getElementById("close-contact-modal");
      const modalRaw = document.getElementById("contact-modal");
      if (!openBtnRaw || !closeBtnRaw || !modalRaw) return;

      const openBtn = openBtnRaw as HTMLButtonElement;
      const closeBtn = closeBtnRaw as HTMLButtonElement;
      const modal = modalRaw as HTMLDivElement;

      function openModal() {
        modal.classList.remove("hidden");
        modal.classList.add("flex");
        document.body.classList.add("overflow-hidden");
        closeBtn.focus();
      }

      function closeModal() {
        modal.classList.add("hidden");
        modal.classList.remove("flex");
        document.body.classList.remove("overflow-hidden");
        openBtn.focus();
      }

      openBtn.addEventListener("click", openModal);
      closeBtn.addEventListener("click", closeModal);
      modal.addEventListener("click", (event) => {
        if (event.target === modal) closeModal();
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && !modal.classList.contains("hidden")) {
          closeModal();
        }
      });
    })();
  </script>
  <script is:inline src="/hardcover-widget.js"></script>
</Layout>
